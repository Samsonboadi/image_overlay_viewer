---
// ImagePanel.astro
---

<section class="image-panel glass-panel">
  <div class="image-container" id="imageContainer">
    <div class="mask-status-badge" id="maskStatusBadge" style="display: none;">
      <span><span class="material-symbols-outlined" style="font-size: 16px;">visibility_off</span> Mask Off</span>
    </div>
    <canvas id="imageCanvas" class="image-display"></canvas>
    <div class="image-info-wrapper">
      <span id="imageInfo">Select images to start</span>
    </div>
  </div>
  <div class="bottom-bar">
    <div class="stats-mini-panel glass-panel">
      <span class="stats-mini-title">Statistics</span>
      <div class="stat-item">
        <span class="stat-label">Index</span>
        <span class="stat-val primary"><span id="currentIndex">0</span> / <span id="totalImages">0</span></span>
      </div>
      <div class="stat-item">
        <span class="stat-label">Approved</span>
        <span class="stat-val approved" id="approvedCount">0</span>
      </div>
      <div class="stat-item">
        <span class="stat-label">Rejected</span>
        <span class="stat-val rejected" id="rejectedCount">0</span>
      </div>
      <div class="stat-item">
        <span class="stat-label">Skipped</span>
        <span class="stat-val skipped" id="skippedCount">0</span>
      </div>
      <div class="stat-item">
        <span class="stat-label">Pending</span>
        <span class="stat-val pending" id="pendingCount">0</span>
      </div>
    </div>
    <div class="export-mini-panel glass-panel">
      <span class="stats-mini-title">Export</span>
      <button class="btn btn-secondary btn-small" id="exportBtn" disabled><span class="material-symbols-outlined">save</span> View</button>
      <button class="btn btn-secondary btn-small" id="exportResultsBtn" disabled><span class="material-symbols-outlined">bar_chart</span> Results</button>
    </div>
    <div class="navigation-bar">
      <button class="nav-btn" id="navPrevBtn" disabled><span class="material-symbols-outlined">arrow_back</span> Previous</button>
      <button class="nav-btn" id="navNextBtn" disabled><span class="material-symbols-outlined">arrow_forward</span> Next</button>
      <button class="nav-btn" id="nextPendingBtn" disabled><span class="material-symbols-outlined">shortcut</span> Pending</button>
    </div>
  </div>
</section>
