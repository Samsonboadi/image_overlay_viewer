---
import Layout from '../layouts/Layout.astro';
import ControlPanel from '../components/ControlPanel.astro';
import ImagePanel from '../components/ImagePanel.astro';
---

<Layout title="Image Overlay Viewer - Geominds">
	<div class="container">
		<main class="main-content">
			<ControlPanel />
			<ImagePanel />
		</main>
	</div>
	
	<!-- Toast notification -->
	<div class="toast" id="toast">
		<span class="toast-icon"><span class="material-symbols-outlined" style="color: #6366f1;">auto_awesome</span></span>
		<span id="toastText">System Ready</span>
	</div>

	<!-- Options Modal -->
	<div class="modal-backdrop" id="optionsModal">
		<div class="modal-content glass-panel" style="max-width: 500px; max-height: 85vh; overflow-y: auto;">
			<div class="modal-header">
				<h2><span class="material-symbols-outlined" style="font-size: 1.6rem; vertical-align: bottom;">settings</span> Advanced Options & Settings</h2>
				<button class="modal-close-btn" id="optionsModalCloseBtn">&times;</button>
			</div>
			<div class="modal-body" style="display: flex; flex-direction: column; gap: 16px;">
				<!-- Navigation Behaviour -->
				<div class="control-group">
					<h3><span class="material-symbols-outlined">explore</span> Navigation</h3>
					<label class="checkbox-container">
						<input type="checkbox" id="autoAdvanceCheckbox" checked>
						<span class="checkbox-checkmark"></span>
						Auto-advance after action
					</label>
					<div style="display: flex; align-items: center; gap: 10px; margin-top: 8px;">
						<label for="maxBatchSizeInput" style="font-size: 0.85rem; color: var(--text-muted); white-space: nowrap;">Folder batch size:</label>
						<input type="number" id="maxBatchSizeInput" min="0" value="1000" style="width: 80px; padding: 4px 8px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 3px; color: var(--text-primary); font-size: 0.85rem;">
						<span style="font-size: 0.78rem; color: var(--text-dim);">0 = unlimited</span>
					</div>
				</div>

				<!-- Session Management -->
				<div class="control-group">
					<h3><span class="material-symbols-outlined">save</span> Session Management</h3>
					<div class="session-controls">
						<button class="btn btn-success btn-small" id="saveSessionBtn"><span class="material-symbols-outlined">save</span> Save</button>
						<button class="btn btn-secondary btn-small" id="loadSessionBtn"><span class="material-symbols-outlined">folder_open</span> Load</button>
						<button class="btn btn-warning btn-small" id="newSessionBtn"><span class="material-symbols-outlined">restart_alt</span> New</button>
					</div>
					<input type="file" id="sessionInput" class="file-input" accept=".json">
					<div id="sessionStatus" style="font-size: 0.78rem; color: var(--text-muted); margin-top: 5px;"></div>
				</div>

				<!-- Mask Classes Configuration -->
				<div class="control-group">
					<h3><span class="material-symbols-outlined">palette</span> Mask Classes</h3>
					<div class="class-count-input">
						<label for="numClassesInput">Number of classes:</label>
						<input type="number" id="numClassesInput" min="1" max="50" value="2">
					</div>

					<div class="background-class-row">
						<label>Background color (unmatched)</label>
						<input type="color" id="backgroundColorPicker" value="#000000" title="Background color">
					</div>

					<div class="class-labels-header">
						<span>Label</span>
						<span>Pixel Val</span>
						<span>Color</span>
						<span></span>
					</div>
					<div class="class-list" id="classListContainer">
						<!-- Dynamic class rows inserted here -->
					</div>
					<div class="class-info" id="classInfo">Configure pixel values and colors for each mask class</div>

					<label class="checkbox-container">
						<input type="checkbox" id="transparentBackgroundCheckbox" checked>
						<span class="checkbox-checkmark"></span>
						Make background transparent
					</label>
				</div>

				<!-- Random Subset -->
				<div class="control-group">
					<h3><span class="material-symbols-outlined">casino</span> Random Subset</h3>
					<div class="slider-container">
						<label for="percentageSlider">Percentage: <span id="percentageValue">20%</span></label>
						<input type="range" id="percentageSlider" class="slider" min="1" max="100" value="20">
					</div>
					<button class="btn btn-warning" id="createSubsetBtn" disabled>Create Random Subset</button>
					<div class="progress-bar" id="progressBar" style="display: none;">
						<div class="progress-fill" id="progressFill"></div>
					</div>
				</div>

				<!-- Download Complete Project -->
				<div class="control-group">
					<h3><span class="material-symbols-outlined">download</span> Download Complete Project</h3>
					<button class="btn btn-warning" id="downloadProjectBtn" disabled><span class="material-symbols-outlined">download</span> Download Sorted Project</button>
					<div class="progress-bar" id="downloadProgress" style="display: none;">
						<div class="progress-fill" id="downloadProgressFill"></div>
					</div>
					<div id="downloadStatus" style="font-size: 0.75rem; color: var(--text-muted); margin-top: 5px; text-align: center;">
						Packages images, masks, and metadata into organized directories.
					</div>
					<div style="margin-top: 10px; display: flex; flex-direction: column; gap: 8px;">
						<label class="checkbox-container">
							<input type="checkbox" id="includeMasksInDownload" checked>
							<span class="checkbox-checkmark"></span>
							Include masks in download
						</label>
						<label class="checkbox-container">
							<input type="checkbox" id="includeOverlaysInDownload">
							<span class="checkbox-checkmark"></span>
							Include overlay previews
						</label>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Help / Shortcuts Modal -->
	<div class="modal-backdrop" id="helpModal">
		<div class="modal-content glass-panel">
			<div class="modal-header">
				<h2><span class="material-symbols-outlined" style="font-size: 1.6rem; vertical-align: bottom;">keyboard</span> Keyboard Shortcuts & Help</h2>
				<button class="modal-close-btn" id="helpModalCloseBtn">&times;</button>
			</div>
			<div class="modal-body">
				<div class="keyboard-shortcuts">
					<div class="shortcut-item">
						<span>Previous Image</span>
						<span class="shortcut-key">←</span>
					</div>
					<div class="shortcut-item">
						<span>Next Image</span>
						<span class="shortcut-key">→</span>
					</div>
					<div class="shortcut-item">
						<span>Approve Status</span>
						<span class="shortcut-key">A</span>
					</div>
					<div class="shortcut-item">
						<span>Reject Status</span>
						<span class="shortcut-key">R</span>
					</div>
					<div class="shortcut-item">
						<span>Skip Status</span>
						<span class="shortcut-key">S</span>
					</div>
					<div class="shortcut-item">
						<span>Reset Zoom</span>
						<span class="shortcut-key">Z</span>
					</div>
					<div class="shortcut-item">
						<span>Jump to Next Pending</span>
						<span class="shortcut-key">J</span>
					</div>
					<div class="shortcut-item">
						<span>Toggle Mask</span>
						<span class="shortcut-key">T</span>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Post-Mask-Load: Upload Images Modal -->
	<div class="modal-backdrop" id="imageUploadModal">
		<div class="modal-content glass-panel" style="max-width: 460px;">
			<div class="modal-header">
				<h2><span class="material-symbols-outlined" style="font-size: 1.6rem; vertical-align: bottom;">photo_camera</span> Upload Images</h2>
				<button class="modal-close-btn" id="imageUploadSkipBtn">&times;</button>
			</div>
			<div class="modal-body" style="display: flex; flex-direction: column; gap: 14px;">
				<p id="imageUploadPrompt" style="font-size: 0.88rem; color: var(--text-muted);">
					Upload the corresponding image files for your masks.
				</p>
				<div class="file-drop-zone" id="imageUploadDropZone">
					<p><span class="material-symbols-outlined" style="font-size: 24px; margin-bottom: 4px;">photo_camera</span> Drop images here or click to browse</p>
					<input type="file" id="imageUploadInput" class="file-input" multiple accept="image/*">
				</div>
				<div class="progress-bar" id="imageUploadProgress" style="display: none;">
					<div class="progress-fill" id="imageUploadProgressFill"></div>
				</div>
				<div id="imageUploadMatchSummary" style="display: none; font-size: 0.82rem; border-radius: 4px; padding: 12px; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05);">
					<div id="imageUploadMatchText"></div>
					<div id="imageUploadUnmatched" style="margin-top: 8px; color: var(--text-dim);"></div>
				</div>
				<div style="display: flex; gap: 8px; margin-top: 4px;">
					<button class="btn btn-secondary" id="imageUploadSkipFooterBtn"><span class="material-symbols-outlined">skip_next</span> Skip</button>
					<button class="btn" id="imageUploadConfirmBtn" style="display: none;"><span class="material-symbols-outlined">check_circle</span> Use These Images</button>
				</div>
			</div>
		</div>
	</div>

	<!-- Post-Image-Load: Upload Masks Modal -->
	<div class="modal-backdrop" id="maskUploadModal">
		<div class="modal-content glass-panel" style="max-width: 460px;">
			<div class="modal-header">
				<h2><span class="material-symbols-outlined" style="font-size: 1.6rem; vertical-align: bottom;">layers</span> Upload Masks</h2>
				<button class="modal-close-btn" id="maskUploadSkipBtn">&times;</button>
			</div>
			<div class="modal-body" style="display: flex; flex-direction: column; gap: 14px;">
				<p id="maskUploadPrompt" style="font-size: 0.88rem; color: var(--text-muted);">
					Upload the corresponding mask files for your images.
				</p>
				<div class="file-drop-zone" id="maskUploadDropZone">
					<p><span class="material-symbols-outlined" style="font-size: 24px; margin-bottom: 4px;">layers</span> Drop masks here or click to browse</p>
					<input type="file" id="maskUploadInput" class="file-input" multiple accept="image/*">
				</div>
				<div class="progress-bar" id="maskUploadProgress" style="display: none;">
					<div class="progress-fill" id="maskUploadProgressFill"></div>
				</div>
				<div id="maskUploadMatchSummary" style="display: none; font-size: 0.82rem; border-radius: 4px; padding: 12px; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05);">
					<div id="maskUploadMatchText"></div>
					<div id="maskUploadUnmatched" style="margin-top: 8px; color: var(--text-dim);"></div>
				</div>
				<div style="display: flex; gap: 8px; margin-top: 4px;">
					<button class="btn btn-secondary" id="maskUploadSkipFooterBtn"><span class="material-symbols-outlined">skip_next</span> Skip</button>
					<button class="btn" id="maskUploadConfirmBtn" style="display: none;"><span class="material-symbols-outlined">check_circle</span> Use These Masks</button>
				</div>
			</div>
		</div>
	</div>

	<!-- Next Batch Modal -->
	<div class="modal-backdrop" id="nextBatchModal">
		<div class="modal-content glass-panel" style="max-width: 360px;">
			<div class="modal-header">
				<h2>Load Next Batch?</h2>
				<button class="modal-close-btn" id="nextBatchModalCloseBtn">&times;</button>
			</div>
			<div class="modal-body">
				<p id="nextBatchMessage" style="font-size: 0.88rem; color: var(--text-muted); margin-bottom: 16px;"></p>
				<div style="display: flex; gap: 8px; flex-wrap: wrap;">
					<button class="btn" id="nextBatchLoadBtn">Load images</button>
					<button class="btn btn-warning" id="nextBatchFirstPendingBtn" style="display:none;">↩ First pending</button>
					<button class="btn btn-secondary" id="nextBatchCancelBtn">Cancel</button>
				</div>
			</div>
		</div>
	</div>

	<!-- New Session Confirm Modal -->
	<div class="modal-backdrop" id="newSessionConfirmModal">
		<div class="modal-content glass-panel" style="max-width: 400px;">
			<div class="modal-header">
				<h2>Start New Session?</h2>
				<button class="modal-close-btn" id="newSessionConfirmCancelBtn">&times;</button>
			</div>
			<div class="modal-body">
				<p style="font-size: 0.88rem; color: var(--text-muted); margin-bottom: 16px;">This will start a new session and clear all statuses from previous images.</p>
				<div style="display: flex; gap: 8px;">
					<button class="btn btn-danger" id="newSessionConfirmOkBtn"><span class="material-symbols-outlined">restart_alt</span> Continue</button>
					<button class="btn btn-secondary" id="newSessionConfirmCancelFooterBtn">Cancel</button>
				</div>
			</div>
		</div>
	</div>

	<!-- Session Resume Modal -->
	<div class="modal-backdrop" id="sessionResumeModal">
		<div class="modal-content glass-panel" style="max-width: 360px;">
			<div class="modal-header">
				<h2><span class="material-symbols-outlined" style="font-size: 1.6rem; vertical-align: bottom;">history</span> Session Restored</h2>
			</div>
			<div class="modal-body">
				<p id="sessionResumeMessage" style="font-size: 0.88rem; color: var(--text-muted); margin-bottom: 16px;"></p>
				<button class="btn" id="sessionResumeContinueBtn">Continue</button>
			</div>
		</div>
	</div>

	<!-- Load Confirmation Modal -->
	<div class="modal-backdrop" id="loadConfirmModal">
		<div class="modal-content glass-panel" style="max-width: 360px;">
			<div class="modal-header">
				<h2 id="loadConfirmTitle">Stack not empty</h2>
				<button class="modal-close-btn" id="loadConfirmCancelBtn">&times;</button>
			</div>
			<div class="modal-body">
				<p id="loadConfirmMessage" style="font-size: 0.88rem; color: var(--text-muted); margin-bottom: 16px;"></p>
				<div style="display: flex; gap: 8px;">
					<button class="btn btn-secondary" id="loadConfirmAppendBtn"><span class="material-symbols-outlined">add</span> Append</button>
					<button class="btn btn-danger" id="loadConfirmReplaceBtn"><span class="material-symbols-outlined">cached</span> Replace</button>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	import { ModernImageOverlayApp } from '../scripts/app.js';

	// Wait for DOM to be ready
	document.addEventListener('DOMContentLoaded', () => {
		const app = new ModernImageOverlayApp();
		
		// Initial canvas resize to match container
		setTimeout(() => app.resizeCanvas(), 150);

		// Handle windows resize
		window.addEventListener('resize', () => {
			setTimeout(() => app.resizeCanvas(), 100);
		});
	});
</script>
